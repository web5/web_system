# ============================================
# 生产环境配置模板
# 部署时复制为 .env.production 并填写实际值
# cp .env.production.example .env.production
# ============================================

# --- 数据库（腾讯云 CDB MySQL 内网地址）---
DB_TYPE=mysql
DB_HOST=172.16.16.10
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_db_password_here
DB_DATABASE=web_system

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379

# --- JWT ---
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_EXPIRES_IN=7d

# --- Gateway ---
PORT=3000
HOST=0.0.0.0
AUTH_SERVICE_URL=http://127.0.0.1:3001
USER_SERVICE_URL=http://127.0.0.1:3002
AI_SERVICE_URL=http://127.0.0.1:3003
PUBLIC_URL=http://106.52.176.246:3000
CORS_ORIGINS=*
