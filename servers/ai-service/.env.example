# AI Service 环境变量模板

# Hy3 API 配置
HY3_API_KEY=your_api_key_here
HY3_BASE_URL=https://wcode.net/api/gpt/v1

# 服务器配置
PORT=3003
NODE_ENV=development

# 数据库配置（MySQL）
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=web_system

# Redis 配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
