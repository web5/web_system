{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ES6",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "lib": ["ES2019", "DOM"],
    "allowJs": true,
    "noEmit": true,
    "types": [
      "miniprogram-api-typings",
      "weixin-miniprogram",
      "jest"
    ]
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
