/* ===== 科豆 AI — Dark Cinema Orange 画板 ===== */
page {
  background: #000000;
  overflow: hidden;
  --primary: #F97316;
  --primary-light: #FB923C;
  --danger: #EF4444;
  --text: #F8FAFC;
  --text-dim: #94A3B8;
  --surface: #0C0C0D;
  --surface2: #111115;
  --shadow: 0 4px 24px rgba(0,0,0,0.5);
}

.container {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: #0A0A0D;
  position: relative;
}

/* ===== 遮罩 ===== */
.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 90;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ===== 图标按钮通用 ===== */
.tb-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.15s;
}
.tb-btn:active { opacity: 0.65; }

.tb-btn.sm { width: 48rpx; height: 48rpx; }
.tb-btn.xs { width: 36rpx; height: 36rpx; }

.tb-btn.dimmed { opacity: 0.3; }

.tb-icon { width: 40rpx; height: 40rpx; }
.tb-icon.sm { width: 32rpx; height: 32rpx; }
.tb-icon.xs { width: 24rpx; height: 24rpx; }

/* ===== 画布 ===== */
.canvas {
  width: 100%;
  flex: 1;
  display: block;
  background: #1a1a1a;
  touch-action: none;
  box-sizing: border-box;
}

/* ===== 图层面板 (右侧浮出) ===== */
.layer-panel {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: 380rpx;
  background: #fff;
  z-index: 105;
  box-shadow: -4px 0 32px rgba(0,0,0,0.15);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.layer-panel.show { transform: translateX(0); }

.lp-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.lp-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e1b4b;
}

.lp-list {
  flex: 1;
  padding: 8rpx 0;
}

.lp-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  gap: 12rpx;
  border-bottom: 1rpx solid #f9fafb;
  transition: background 0.15s;
}
.lp-item.active {
  background: #eef2ff;
}
.lp-item:active {
  background: #f3f4f6;
}

.lp-vis {
  flex-shrink: 0;
}

.lp-name {
  flex: 1;
  font-size: 26rpx;
  color: #374151;
}

.lp-badge {
  color: #f97316;
  font-size: 32rpx;
  font-weight: 700;
  width: 16rpx;
  text-align: center;
}

/* 图层排序按钮 */
.lp-move-btn {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  opacity: 0.3;
  transition: opacity 0.15s;
}
.lp-move-btn:active {
  opacity: 0.7;
}
.lp-move-btn.disabled {
  opacity: 0.1;
  pointer-events: none;
}

.lp-move-icon {
  font-size: 20rpx;
  line-height: 1;
  color: #6b7280;
}

.lp-footer {
  display: flex;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #f3f4f6;
}

.lp-fbtn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 14rpx 0;
  background: #f3f4f6;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #4b5563;
  transition: background 0.15s;
}
.lp-fbtn:active { background: #e5e7eb; }

/* ===== 底部缩放工具栏 ===== */
.fab-zoom-bar {
  position: fixed;
  bottom: 150rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  padding: 10rpx 18rpx;
  background: rgba(30, 27, 75, 0.92);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 48rpx;
  box-shadow: 0 8px 30px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.12);
  z-index: 95;
  border: 1rpx solid rgba(255,255,255,0.15);
  transition: opacity 0.2s ease, visibility 0.2s ease;
}

/* 绘制时隐藏 */
.fab-zoom-bar.toolbar-hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

/* ===== 底部功能工具栏 ===== */
.fab-action-bar {
  position: fixed;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 18rpx;
  background: rgba(30, 27, 75, 0.92);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 56rpx;
  box-shadow: 0 12px 40px rgba(0,0,0,0.22), inset 0 1px 0 rgba(255,255,255,0.12);
  z-index: 95;
  border: 1rpx solid rgba(255,255,255,0.15);
}

/* 张小龙：统一底部功能按钮和缩放按钮大小 */
.fab-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.18s;
  flex-shrink: 0;
}
.fab-btn:active {
  background: rgba(255,255,255,0.28);
  transform: scale(0.92);
}


/* 张小龙：图标等比例缩小，匹配 72rpx 按钮 */
.fab-icon {
  width: 32rpx;
  height: 32rpx;
}

.fab-color-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 3rpx rgba(255,255,255,0.35);
}

/* ===== 笔刷弹出菜单（长按颜色触发） ===== */
.brush-menu {
  position: fixed;
  bottom: 260rpx;
  left: 50%;
  transform: translateX(-50%) translateY(12rpx) scale(0.95);
  background: rgba(30, 27, 75, 0.94);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 16rpx 16rpx 12rpx;
  box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  border: 1rpx solid rgba(255,255,255,0.12);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.brush-menu.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0) scale(1);
  pointer-events: auto;
}

.bm-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: nowrap;
}

.bm-brush {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.15s;
  border: 2rpx solid transparent;
  flex-shrink: 0;
}
.bm-brush.active {
  background: rgba(249,115,22,0.2);
  border-color: rgba(249,115,22,0.5);
}
.bm-brush:active {
  background: rgba(255,255,255,0.12);
}

.bm-icon {
  width: 32rpx;
  height: 32rpx;
}

.bm-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 500;
  white-space: nowrap;
}
.bm-brush.active .bm-label {
  color: #FB923C;
}

/* 预设图形图标 */
.bm-shape-icon {
  font-size: 36rpx;
  line-height: 1;
  display: block;
}

/* 图形行分隔 */
.bm-shapes {
  padding-top: 12rpx;
  margin-top: 12rpx;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

.bm-slider-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

.bm-size-dot {
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  flex-shrink: 0;
  transition: width 0.1s, height 0.1s;
}

.bm-slider {
  flex: 1;
}

/* 高级工具行分隔 */
.bm-tools {
  padding-top: 12rpx;
  margin-top: 12rpx;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

/* ===== 滑出面板 ===== */
.slide-panel {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #0C0C0D;
  border-top: 1rpx solid rgba(249,115,22,0.15);
  border-radius: 32rpx 32rpx 0 0;
  padding: 16rpx 24rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 100;
  box-shadow: 0 -8px 40px rgba(0,0,0,0.5);
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.slide-panel.show {
  transform: translateY(0);
}

.sp-handle {
  width: 48rpx;
  height: 6rpx;
  background: rgba(249,115,22,0.3);
  border-radius: 3rpx;
  margin: 0 auto 20rpx;
}

.sp-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #F8FAFC;
  margin-bottom: 20rpx;
}

/* ===== 笔刷网格 ===== */
.sp-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: nowrap;
}

.sp-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 4rpx;
  border-radius: 20rpx;
  background: #f3f4f6;
  gap: 10rpx;
  transition: all 0.2s;
  border: 2rpx solid transparent;
}
.sp-item.active {
  background: #eef2ff;
  border-color: #f97316;
}
.sp-item:active {
  background: #e5e7eb;
  transform: scale(0.96);
}
.sp-item.danger { background: #fef2f2; }
.sp-item.danger:active { background: #fee2e2; }

.sp-icon {
  width: 44rpx;
  height: 44rpx;
}

.sp-label {
  font-size: 22rpx;
  color: #4b5563;
  font-weight: 500;
  white-space: nowrap;
}
.sp-item.active .sp-label { color: #f97316; }
.sp-item.danger .sp-label { color: #ef4444; }

/* ===== 颜色网格 ===== */
.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-dot {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  position: relative;
  transition: all 0.15s;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
.color-dot.active {
  border-color: #f97316;
  box-shadow: 0 0 0 6rpx rgba(79,70,229,0.2);
  transform: scale(1.1);
}
.color-dot:active {
  transform: scale(0.92);
}

.color-dot-ring {
  position: absolute;
  inset: 25%;
  border-radius: 50%;
  border: 2rpx solid #d1d5db;
}

/* 透明色棋盘格 */
.color-dot-transparent {
  background-image:
    linear-gradient(45deg, #ccc 25%, transparent 25%),
    linear-gradient(-45deg, #ccc 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, #ccc 75%),
    linear-gradient(-45deg, transparent 75%, #ccc 75%);
  background-size: 23rpx 23rpx;
  background-position: 0 0, 0 11rpx, 11rpx -11rpx, -11rpx 0;
  border: 4rpx solid #d1d5db;
}

/* ===== 设置面板 ===== */
.st-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 8rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.st-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.st-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.55;
}

.st-label {
  font-size: 28rpx;
  color: #F8FAFC;
  font-weight: 600;
}

.st-hint {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: 8rpx;
}

.st-switch {
  flex-shrink: 0;
  transform: scale(1.1);
}

.st-arrow {
  font-size: 28rpx;
  color: #9ca3af;
}

/* ===== 取色中提示条 ===== */
.pick-color-bar {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 28rpx;
  background: rgba(249,115,22,0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 48rpx;
  box-shadow: 0 8px 32px rgba(249,115,22,0.35);
  z-index: 60;
  opacity: 0;
  pointer-events: none;
  transition: all 0.2s ease;
}
.pick-color-bar.show {
  opacity: 1;
  pointer-events: auto;
  transform: translate(-50%, -50%) scale(1);
}

.pik-sign {
  font-size: 32rpx;
}

.pik-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  white-space: nowrap;
}

/* ===== 底部缩放控件组 ===== */
.fab-zoom-group {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

/* 张小龙：缩放按钮与功能按钮完全一致 */
.fab-zbtn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
  flex-shrink: 0;
}
.fab-zbtn:active {
  background: rgba(255,255,255,0.28);
  transform: scale(0.9);
}
.fab-zbtn.active {
  background: rgba(255,255,255,0.30);
  box-shadow: 0 0 0 2rpx rgba(255,255,255,0.4);
}

.fab-zsign {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1;
}

.fab-zlevel {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.75);
  min-width: 64rpx;
  text-align: center;
  padding: 6rpx 2rpx;
  border-radius: 8rpx;
  transition: all 0.15s;
  flex-shrink: 0;
}
.fab-zreset {
  color: #a5b4fc;
}
.fab-zlevel:active {
  background: rgba(255,255,255,0.12);
}

.fab-zdivider {
  width: 1rpx;
  height: 32rpx;
  background: rgba(255,255,255,0.18);
  margin: 0 2rpx;
  flex-shrink: 0;
}

.fab-zicon {
  width: 28rpx;
  height: 28rpx;
}

.fab-zbtn.disabled {
  opacity: 0.3;
  pointer-events: none;
}

/* ===== 右上角完成按钮（张小龙：用完即走） ===== */
.done-btn {
  position: fixed;
  top: calc(24rpx + env(safe-area-inset-top));
  right: calc(24rpx + env(safe-area-inset-right));
  z-index: 100;
  padding: 14rpx 36rpx;
  background: rgba(249,115,22,0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 40rpx;
  box-shadow: 0 4px 20px rgba(249,115,22,0.35);
  transition: all 0.2s;
}
.done-btn:active {
  transform: scale(0.92);
  background: rgba(249,115,22,1);
}
.done-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* ===== 顶部素材选择栏 ===== */
.material-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  padding-top: calc(12rpx + env(safe-area-inset-top));
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 2px 16px rgba(0,0,0,0.08);
  z-index: 45;
  gap: 8rpx;
  transform: translateY(-120%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  opacity: 0;
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
}

.material-bar.show {
  transform: translateY(0);
  opacity: 1;
}

.mb-categories {
  flex-shrink: 0;
  max-width: 280rpx;
  height: 56rpx;
  overflow-x: auto;
  overflow-y: hidden;
  white-space: nowrap;
}

.mb-cat {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #6b7280;
  background: #f3f4f6;
  margin-right: 8rpx;
  transition: all 0.2s ease;
}
.mb-cat.active {
  background: #f97316;
  color: #fff;
}
.mb-cat:active {
  opacity: 0.7;
}

.mb-list {
  flex: 1;
  min-width: 0;
  height: 56rpx;
  overflow-x: auto;
  overflow-y: hidden;
  white-space: nowrap;
}

.mb-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  padding: 6rpx 10rpx;
  border-radius: 12rpx;
  margin-right: 2rpx;
  transition: background 0.15s;
}
.mb-item:active {
  background: #f3f4f6;
  transform: scale(0.95);
}

.mb-item-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.mb-item-name {
  font-size: 16rpx;
  color: #9ca3af;
}

.mb-close {
  flex-shrink: 0;
  padding: 8rpx;
  opacity: 0.4;
  transition: opacity 0.15s;
}
.mb-close:active {
  opacity: 0.7;
}

/* ===== iPad 适配 ===== */

/* ---- iPad 竖屏：工具栏保持在底部（张小龙：符合握持习惯） ---- */
/* 不需要特殊样式，保持原有底部布局即可 */

/* ---- iPad 竖屏：画布不需要留边距 ---- */
.ipad:not(.landscape) .canvas {
  padding-left: 0;
  padding-right: 0;
}

/* ---- iPad 横屏：画布留出空间给侧边栏 ---- */
.ipad.landscape .canvas {
  padding-left: 180rpx;
  padding-right: 100rpx;
}

/* ---- iPad 横屏：素材侧边栏保持左侧（基础样式已定义） ---- */

/* ---- 工具栏区域 ---- */
.toolbar-area {
  /* 竖屏：无额外样式，子元素按原 fixed 定位 */
}

/* iPad 横屏：工具栏改为右侧固定边栏 */
.toolbar-area.toolbar-sidebar {
  position: fixed;
  right: 16rpx;
  right: calc(16rpx + env(safe-area-inset-right));
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  z-index: 110;
  width: auto;
  max-height: 85vh;
  overflow-y: auto;
  /* 隐藏滚动条 */
  scrollbar-width: none;
}
.toolbar-area.toolbar-sidebar::-webkit-scrollbar {
  display: none;
}

/* 横屏侧边栏：缩放栏重设为垂直圆角容器 */
.toolbar-area.toolbar-sidebar .fab-zoom-bar {
  position: static;
  transform: none;
  left: auto;
  bottom: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 10rpx;
  border-radius: 32rpx;
}

/* 横屏侧边栏：功能按钮栏重设为垂直圆角容器 */
.toolbar-area.toolbar-sidebar .fab-action-bar {
  position: static;
  transform: none;
  left: auto;
  bottom: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 10rpx;
  border-radius: 36rpx;
}

/* 横屏侧边栏：缩放控件组竖排 */
.toolbar-area.toolbar-sidebar .fab-zoom-group {
  flex-direction: column;
  gap: 8rpx;
}

/* 横屏侧边栏：缩放数字横排显示 */
.toolbar-area.toolbar-sidebar .fab-zlevel {
  min-width: auto;
  text-align: center;
  padding: 4rpx 0;
  writing-mode: horizontal-tb;
}

/* 横屏侧边栏：分隔线改为横向短横线 */
.toolbar-area.toolbar-sidebar .fab-zdivider {
  width: 32rpx;
  height: 1rpx;
  margin: 6rpx 0;
  flex-shrink: 0;
}

/* ---- iPad 通用：触控元素适当放大，按钮大小统一 ---- */
.ipad .fab-btn {
  width: 76rpx;
  height: 76rpx;
}

.ipad .fab-icon {
  width: 38rpx;
  height: 38rpx;
}

.ipad .fab-color-dot {
  width: 42rpx;
  height: 42rpx;
}

.ipad .fab-zbtn {
  width: 76rpx;
  height: 76rpx;
}

.ipad .fab-zsign {
  font-size: 30rpx;
}

.ipad .fab-zicon {
  width: 36rpx;
  height: 36rpx;
}

.ipad .fab-zlevel {
  font-size: 22rpx;
  min-width: 64rpx;
}

/* ---- iPad 面板内边距 & 文字 ---- */
.ipad .slide-panel {
  padding: 20rpx 32rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.ipad .sp-handle {
  width: 48rpx;
  height: 6rpx;
  margin-bottom: 20rpx;
}

.ipad .sp-title {
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.ipad .sp-icon {
  width: 44rpx;
  height: 44rpx;
}

.ipad .sp-label {
  font-size: 24rpx;
}

.ipad .sp-item {
  padding: 22rpx 6rpx;
}

.ipad .color-dot {
  width: 68rpx;
  height: 68rpx;
}

.ipad .color-grid {
  gap: 16rpx;
}

/* ---- iPad 图层 ---- */
.ipad .layer-panel {
  width: 360rpx;
}

.ipad .lp-title {
  font-size: 28rpx;
}

.ipad .lp-header {
  padding: 22rpx 20rpx;
}

.ipad .lp-name {
  font-size: 24rpx;
}

.ipad .lp-item {
  padding: 16rpx 20rpx;
}

.ipad .lp-fbtn {
  font-size: 22rpx;
  padding: 14rpx 0;
}

/* ---- iPad 笔刷菜单 ---- */
.ipad .brush-menu {
  padding: 18rpx 16rpx 12rpx;
  border-radius: 24rpx;
}

.ipad .bm-icon {
  width: 32rpx;
  height: 32rpx;
}

.ipad .bm-label {
  font-size: 20rpx;
}

.ipad .bm-brush {
  padding: 14rpx 16rpx;
}

.ipad .bm-shape-icon {
  font-size: 36rpx;
}

/* ---- iPad 设置面板 ---- */
.ipad .st-label {
  font-size: 30rpx;
}

.ipad .st-hint {
  font-size: 24rpx;
}

.ipad .st-row {
  padding: 28rpx 8rpx;
}

/* ---- iPad 横屏：侧边栏整体更紧凑 ---- */
.ipad.landscape .toolbar-area.toolbar-sidebar {
  gap: 10rpx;
}

.ipad.landscape .toolbar-area.toolbar-sidebar .fab-zoom-bar,
.ipad.landscape .toolbar-area.toolbar-sidebar .fab-action-bar {
  padding: 8rpx 8rpx;
}

.ipad.landscape .toolbar-area.toolbar-sidebar .fab-zoom-group {
  gap: 4rpx;
}

.ipad.landscape .toolbar-area.toolbar-sidebar .fab-action-bar {
  gap: 4rpx;
}

.ipad.landscape .toolbar-area.toolbar-sidebar .fab-zdivider {
  width: 24rpx;
  margin: 3rpx 0;
}

/* ---- iPad 横屏：侧边栏按钮更紧凑 ---- */
.ipad.landscape .fab-btn,
.ipad.landscape .fab-zbtn {
  width: 60rpx;
  height: 60rpx;
}

.ipad.landscape .fab-icon {
  width: 30rpx;
  height: 30rpx;
}

.ipad.landscape .fab-zicon {
  width: 28rpx;
  height: 28rpx;
}

.ipad.landscape .fab-zsign {
  font-size: 24rpx;
}

.ipad.landscape .fab-color-dot {
  width: 34rpx;
  height: 34rpx;
}

.ipad.landscape .fab-zlevel {
  font-size: 20rpx;
  min-width: 48rpx;
  padding: 2rpx 0;
}

/* ---- iPad 横屏：笔刷菜单贴右侧边栏 ---- */
.ipad.landscape .brush-menu {
  left: auto;
  right: 120rpx;
  bottom: 50%;
  transform: translateY(50%) translateY(12rpx) scale(0.95);
}

.ipad.landscape .brush-menu.show {
  transform: translateY(50%) translateY(0) scale(1);
}

/* ---- iPad 素材栏 ---- */
.ipad .material-bar {
  padding: 12rpx 20rpx;
  padding-top: calc(12rpx + env(safe-area-inset-top));
}

.ipad .mb-cat {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
}

.ipad .mb-item-icon {
  width: 36rpx;
  height: 36rpx;
}

.ipad .mb-item-name {
  font-size: 18rpx;
}

/* ---- iPad 竖屏：素材栏改到工具栏上方（张小龙：符合握持习惯） ---- */
.ipad:not(.landscape) .material-bar {
  top: auto;
  bottom: 0;
  bottom: calc(0 + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(120%);
}

.ipad:not(.landscape) .material-bar.show {
  transform: translateY(0);
}

/* ===== 空白画布引导（张小龙：降低小白用户的空白恐惧）===== */
.guide-hint {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 80; /* 在画布上方，但在工具栏下方 */
  animation: guideFadeIn 0.5s ease;
}

.guide-text {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
  margin-bottom: 20rpx;
}

.guide-subtext {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

@keyframes guideFadeIn {
  from { opacity: 0; transform: translate(-50%, -50%) scale(0.9); }
  to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
}

/* ===== iPad 素材侧边栏（张小龙：充分利用大屏幕）===== */
.material-sidebar {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: 180rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 2px 0 16px rgba(0,0,0,0.08);
  z-index: 100;
  display: flex;
  flex-direction: column;
  padding: 16rpx 12rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  transform: translateX(-100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* iPad 横屏：素材侧边栏保持左侧（基础样式已处理） */
/* .ipad.landscape .material-sidebar 使用基础样式（left: 0; translateX(-100%)） */

.material-sidebar.show {
  transform: translateX(0);
}

/* 分类标签（垂直排列） */
.ms-categories {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.ms-cat {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 6rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #6b7280;
  background: #f3f4f6;
  transition: all 0.2s ease;
}

.ms-cat.active {
  background: #f97316;
  color: #fff;
}

.ms-cat:active {
  opacity: 0.7;
}

/* 素材列表（垂直排列，可滚动） */
.ms-list {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 8rpx 0;
}

.ms-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 6rpx;
  border-radius: 12rpx;
  background: #fff;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  transition: all 0.2s ease;
}

.ms-item:active {
  background: #f3f4f6;
  transform: scale(0.95);
}

.ms-item-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.ms-item-name {
  font-size: 18rpx;
  color: #374151;
  text-align: center;
}

/* 关闭按钮 */
.ms-close {
  position: absolute;
  top: calc(16rpx + env(safe-area-inset-top));
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0,0,0,0.05);
  transition: background 0.2s ease;
}

.ms-close:active {
  background: rgba(0,0,0,0.1);
}
