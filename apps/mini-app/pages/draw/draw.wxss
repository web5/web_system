page {
  background: #fff;
}

.draw-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #fff;
}

.draw-canvas {
  width: 100%;
  height: calc(100vh - 120rpx);
  display: block;
  background: white;
}

.toolbar {
  background: white;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.color-bar {
  display: flex;
  gap: 15rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.color-item {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
}

.color-item.active {
  border-color: #667eea;
  box-shadow: 0 0 10rpx rgba(102, 126, 234, 0.5);
}

.tools {
  display: flex;
  gap: 20rpx;
}

.tool-btn {
  flex: 1;
  background: #667eea;
  color: white;
  border-radius: 10rpx;
  font-size: 28rpx;
}
