<view class="container {{isIPad ? 'ipad' : ''}} {{isIPad && isLandscape ? 'landscape' : ''}}">
  <!-- 右上角完成按钮（张小龙：用完即走，画完自然分享） -->
  <view class="done-btn" bindtap="onDone" wx:if="{{!isPickingColor && !addingShape}}">
    <text class="done-text">完成</text>
  </view>

  <!-- 遮罩层（取色模式下不显示，避免阻挡画布点击） -->
  <view
    class="overlay"
    wx:if="{{!isPickingColor && (showBrushPanel || showColorPanel || showActionPanel || showLayers || showBrushMenu || showSettings)}}"
    bindtap="closeAllPanels"
  ></view>

  <!-- 顶部/底部素材选择栏（手机端 + iPad 竖屏） -->
  <view class="material-bar {{showMaterialBar && !isPickingColor && !isDrawing ? 'show' : ''}}"
        wx:if="{{showMaterialBar && !(isIPad && isLandscape)}}">
    <!-- 分类标签 -->
    <view class="mb-categories">
      <view class="mb-cat {{activeMaterialCategory === item.key ? 'active' : ''}}"
            wx:for="{{materialCategories}}" wx:key="key"
            data-category="{{item.key}}"
            bindtap="onMaterialCategoryChange">{{item.name}}</view>
    </view>

    <!-- 素材列表 -->
    <view class="mb-list">
      <view class="mb-item" wx:for="{{filteredMaterials}}" wx:key="id" wx:for-item="material"
            data-material="{{material}}" bindtap="onSelectMaterial">
        <image class="mb-item-icon" src="{{material.icon}}" mode="aspectFit" />
        <text class="mb-item-name">{{material.name}}</text>
      </view>
    </view>

    <!-- 关闭按钮 -->
    <view class="mb-close" bindtap="toggleMaterialBar">
      <image class="tb-icon xs" src="{{icons.close}}" mode="aspectFit" />
    </view>
  </view>

  <!-- iPad 横屏素材侧边栏 -->
  <view class="material-sidebar {{showMaterialBar && !isPickingColor && !isDrawing ? 'show' : ''}}"
        wx:if="{{showMaterialBar && isIPad && isLandscape}}">
    <!-- 分类标签（垂直排列） -->
    <view class="ms-categories">
      <view class="ms-cat {{activeMaterialCategory === item.key ? 'active' : ''}}"
            wx:for="{{materialCategories}}" wx:key="key"
            data-category="{{item.key}}"
            bindtap="onMaterialCategoryChange">{{item.name}}</view>
    </view>

    <!-- 素材列表（垂直排列） -->
    <view class="ms-list">
      <view class="ms-item" wx:for="{{filteredMaterials}}" wx:key="id" wx:for-item="material"
            data-material="{{material}}" bindtap="onSelectMaterial">
        <image class="ms-item-icon" src="{{material.icon}}" mode="aspectFit" />
        <text class="ms-item-name">{{material.name}}</text>
      </view>
    </view>

    <!-- 关闭按钮 -->
    <view class="ms-close" bindtap="toggleMaterialBar">
      <image class="tb-icon xs" src="{{icons.close}}" mode="aspectFit" />
    </view>
  </view>

  <!-- 空白画布引导（张小龙：降低小白用户的空白恐惧） -->
  <view class="guide-hint" wx:if="{{showGuide}}">
    <text class="guide-text">点击这里开始画 ✏️</text>
    <text class="guide-subtext">试试画一条线</text>
  </view>

  <!-- 画布 -->
  <canvas
    type="2d"
    id="drawCanvas"
    class="canvas"
    data-test="draw-canvas"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  ></canvas>

  <!-- 图层面板 -->
  <view class="layer-panel {{showLayers ? 'show' : ''}}">
    <view class="lp-header">
      <text class="lp-title">图层</text>
      <view class="tb-btn sm" bindtap="toggleLayers">
        <image class="tb-icon sm" src="{{icons.close}}" mode="aspectFit" />
      </view>
    </view>
    <scroll-view class="lp-list" scroll-y>
      <view
        class="lp-item {{item.active ? 'active' : ''}}"
        wx:for="{{layers}}"
        wx:key="id"
        data-index="{{index}}"
        bindtap="selectLayer"
      >
        <view class="lp-vis" catchtap="toggleLayerVisible" data-index="{{index}}">
          <image class="tb-icon xs" src="{{item.visible ? icons.eye : icons.eyeOff}}" mode="aspectFit" />
        </view>
        <text class="lp-name">{{item.name}}</text>
        <text class="lp-badge" wx:if="{{item.active}}">·</text>
        <!-- 拖动排序按钮 -->
        <view class="lp-move-btn {{index === 0 ? 'disabled' : ''}}" catchtap="moveLayerUp" data-index="{{index}}">
          <text class="lp-move-icon">▲</text>
        </view>
        <view class="lp-move-btn {{index === layers.length - 1 ? 'disabled' : ''}}" catchtap="moveLayerDown" data-index="{{index}}">
          <text class="lp-move-icon">▼</text>
        </view>
      </view>
    </scroll-view>
    <view class="lp-footer">
      <view class="lp-fbtn" bindtap="addLayer">
        <image class="tb-icon xs" src="{{icons.plus}}" mode="aspectFit" />
        <text>新建</text>
      </view>
      <view class="lp-fbtn" bindtap="deleteLayer">
        <image class="tb-icon xs" src="{{icons.trash}}" mode="aspectFit" />
        <text>删除</text>
      </view>
      <view class="lp-fbtn" bindtap="mergeDown">
        <image class="tb-icon xs" src="{{icons.merge}}" mode="aspectFit" />
        <text>合并</text>
      </view>
    </view>
  </view>



  <!-- 设置面板（张小龙：隐藏专业功能，智能触发） -->
  <view class="slide-panel {{showSettings ? 'show' : ''}}">
    <view class="sp-handle"></view>
    <view class="sp-title">设置</view>
    <view class="st-row">
      <view class="st-left" bindtap="onResetView">
        <image class="st-icon" src="{{icons.reset}}" mode="aspectFit" />
        <text class="st-label">重置视角</text>
      </view>
    </view>
  </view>

  <!-- 笔刷弹出菜单（张小龙：极简主义，只保留 6 个核心功能） -->
  <view class="brush-menu {{showBrushMenu ? 'show' : ''}}" wx:if="{{showBrushMenu}}">
    <!-- 核心笔刷（3 个） -->
    <view class="bm-row">
      <view
        class="bm-brush {{currentBrush === 'pencil' ? 'active' : ''}}"
        data-type="pencil"
        bindtap="selectBrush"
      >
        <image class="bm-icon" src="{{iconsWhite.pencil}}" mode="aspectFit" />
        <text class="bm-label">铅笔</text>
      </view>
      <view
        class="bm-brush {{currentBrush === 'marker' ? 'active' : ''}}"
        data-type="marker"
        bindtap="selectBrush"
      >
        <image class="bm-icon" src="{{iconsWhite.marker}}" mode="aspectFit" />
        <text class="bm-label">马克笔</text>
      </view>
      <view
        class="bm-brush {{currentBrush === 'eraser' ? 'active' : ''}}"
        data-type="eraser"
        bindtap="selectBrush"
      >
        <image class="bm-icon" src="{{iconsWhite.eraser}}" mode="aspectFit" />
        <text class="bm-label">橡皮</text>
      </view>
    </view>

    <!-- 粗细滑块 -->
    <view class="bm-slider-row">
      <view class="bm-size-dot" style="width:{{brushSize*2}}rpx; height:{{brushSize*2}}rpx"></view>
      <slider
        class="bm-slider"
        min="1"
        max="40"
        value="{{brushSize}}"
        bindchange="onBrushSizeChange"
        block-size="18"
        activeColor="#f97316"
        backgroundColor="rgba(255,255,255,0.2)"
      />
    </view>

    <!-- 核心功能（3 个） -->
    <view class="bm-row bm-core">
      <view class="bm-brush {{addingShape ? 'active' : ''}}" bindtap="toggleShapePanel">
        <text class="bm-shape-icon">◆</text>
        <text class="bm-label">图形</text>
      </view>
      <!-- 素材库不再通过工具栏控制，自动根据画布状态显示 -->
      <view class="bm-brush" bindtap="onSave">
        <image class="bm-icon" src="{{iconsWhite.download}}" mode="aspectFit" />
        <text class="bm-label">保存</text>
      </view>
    </view>
  </view>

  <!-- 图形选择面板（点击"图形"后展开） -->
  <view class="shape-panel {{showShapePanel ? 'show' : ''}}" wx:if="{{showShapePanel}}">
    <view class="sp-header">
      <text class="sp-title">选择图形</text>
      <view class="sp-close" bindtap="toggleShapePanel">
        <image class="tb-icon xs" src="{{icons.close}}" mode="aspectFit" />
      </view>
    </view>
    <view class="sp-shapes">
      <view
        class="sp-shape {{addingShape === item.type ? 'active' : ''}}"
        wx:for="{{shapes}}"
        wx:key="type"
        data-shape="{{item.type}}"
        bindtap="selectShape"
      >
        <text class="sp-shape-icon">{{item.icon}}</text>
        <text class="sp-shape-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 取色中提示条 -->
  <view class="pick-color-bar {{isPickingColor ? 'show' : ''}}" bindtap="cancelPickColor">
    <text class="pik-sign">💉</text>
    <text class="pik-text">点击画布取色 · 点此取消</text>
  </view>

  <!-- 放置图形提示条 -->
  <view class="pick-color-bar {{addingShape ? 'show' : ''}}" bindtap="cancelAddShape">
    <text class="pik-sign">{{currentShapeIcon}}</text>
    <text class="pik-text">点击画布放置图形 · 点此取消</text>
  </view>

  <!-- 工具栏区域（竖屏底部 / iPad 横屏右侧边栏） -->
  <view class="toolbar-area {{isIPad && isLandscape ? 'toolbar-sidebar' : ''}}">

  <!-- 底部缩放工具栏（绘制时隐藏） -->
  <view class="fab-zoom-bar {{isDrawing ? 'toolbar-hidden' : ''}}">
    <view class="fab-zoom-group">
      <view class="fab-zbtn {{isCanvasMode ? 'active' : ''}}" bindtap="toggleCanvasMode">
        <text class="fab-zsign">✋</text>
      </view>
      <view class="fab-zdivider"></view>
      <view class="fab-zbtn" bindtap="onZoomOut">
        <text class="fab-zsign">−</text>
      </view>
      <text class="fab-zlevel {{zoomLevel === 100 ? '' : 'fab-zreset'}}" bindtap="onZoomReset">{{zoomLevel}}%</text>
      <view class="fab-zbtn" bindtap="onZoomIn">
        <text class="fab-zsign">+</text>
      </view>
      <view class="fab-zbtn" bindtap="onResetView">
        <image class="fab-zicon" src="{{icons.reset}}" mode="aspectFit" />
      </view>
      <view class="fab-zdivider"></view>
      <view class="fab-zbtn {{canUndo ? '' : 'disabled'}}" bindtap="onUndo">
        <image class="fab-zicon" src="{{iconsWhite.undo}}" mode="aspectFit" />
      </view>
      <view class="fab-zbtn {{canRedo ? '' : 'disabled'}}" bindtap="onRedo">
        <image class="fab-zicon" src="{{iconsWhite.redo}}" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- 底部功能工具栏（绘制时隐藏） -->
  <view class="fab-action-bar {{isDrawing ? 'toolbar-hidden' : ''}}">
    <view class="fab-btn" data-test="color-btn" bindtap="openColorPanel" bindlongpress="onColorLongPress">
      <view class="fab-color-dot" style="background:{{currentColor}}"></view>
    </view>

    <view class="fab-btn" wx:if="{{showLayerButton}}" data-test="layer-btn" bindtap="toggleLayers">
        <image class="fab-icon" src="{{iconsWhite.layers}}" mode="aspectFit" />
      </view>

    <view class="fab-btn" data-test="clear-btn" bindtap="onClear">
        <image class="fab-icon" src="{{iconsWhite.trash}}" mode="aspectFit" />
      </view>

    <view class="fab-btn" data-test="tool-btn" bindtap="onToolTap" bindlongpress="onToolLongPress">
        <image class="fab-icon" src="{{iconsWhite.tool}}" mode="aspectFit" />
      </view>
  </view>

  </view>
  <!-- /工具栏区域 -->

  <!-- 笔刷面板 -->
  <view class="slide-panel {{showBrushPanel ? 'show' : ''}}">
    <view class="sp-handle"></view>
    <view class="sp-title">选择笔刷</view>
    <view class="sp-grid">
      <view
        class="sp-item {{currentBrush === item.type ? 'active' : ''}}"
        wx:for="{{brushes}}"
        wx:key="type"
        data-type="{{item.type}}"
        bindtap="selectBrush"
      >
        <image class="sp-icon" src="{{item.icon}}" mode="aspectFit" />
        <text class="sp-label">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 颜色面板 -->
  <view class="slide-panel {{showColorPanel ? 'show' : ''}}">
    <view class="sp-handle"></view>
    <view class="sp-title">{{showBgColors ? '选择背景色' : isPickingBackground ? '选择背景色' : '选择颜色'}}</view>
    <view class="color-grid">
      <view
        class="color-dot {{(showBgColors ? (item === 'transparent' ? backgroundColor === '' : backgroundColor === item) : currentColor === item) ? 'active' : ''}} {{item === 'transparent' ? 'color-dot-transparent' : ''}}"
        wx:for="{{showBgColors ? bgColors : colors}}"
        wx:key="*this"
        style="{{item === 'transparent' ? '' : 'background:' + item}}"
        data-color="{{item}}"
        bindtap="selectColor"
      >
        <view wx:if="{{item === '#ffffff'}}" class="color-dot-ring"></view>
      </view>
    </view>
  </view>
</view>
