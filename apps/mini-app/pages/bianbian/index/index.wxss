/* 变变首页 — 暖白风格 */

.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 12vh 44rpx 8vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #FFF8F0 0%, #FFF0E0 60%, #FFE8D6 100%);
}

/* 品牌区 */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 6vh;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.brand-star {
  font-size: 64rpx;
  color: #FF8C42;
  line-height: 1;
}

.brand-name {
  font-size: 64rpx;
  font-weight: 800;
  color: #FF8C42;
  letter-spacing: 6rpx;
}

.brand-slogan {
  font-size: 26rpx;
  color: #BBB;
  letter-spacing: 4rpx;
}

/* 卡片 */
.card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(255, 140, 66, 0.06);
  transition: transform 0.15s;
}

.card:active {
  transform: scale(0.97);
}

.card-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #999;
}

/* 上次创作提示 */
.draft-hint {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 20rpx 28rpx;
  margin-top: 8rpx;
  background: rgba(255, 140, 66, 0.06);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 140, 66, 0.1);
}

.draft-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.draft-text {
  font-size: 24rpx;
  color: #FF8C42;
}
