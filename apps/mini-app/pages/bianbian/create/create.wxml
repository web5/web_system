<!-- 变变创作页 v2 -->
<view class="page">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="btn-back" bindtap="goBack">
      <text>← 返回</text>
    </view>
    <text class="top-title">变变</text>
    <view class="btn-transform-wrap {{elements.length === 0 ? 'disabled' : ''}}" bindtap="doTransform">
      <text>变变！✨</text>
    </view>
  </view>

  <!-- 画布区域 -->
  <view class="canvas-area" id="canvasArea">
    <canvas
      type="2d"
      id="bianbianCanvas"
      class="canvas"
      style="width: {{canvasWidth}}px; height: {{canvasHeight}}px; background: {{canvasBg}};"
      bindtouchstart="onCanvasTouchStart"
      bindtouchmove="onCanvasTouchMove"
      bindtouchend="onCanvasTouchEnd"
    />

    <!-- 空状态引导 -->
    <view wx:if="{{elements.length === 0}}" class="canvas-empty">
      <text class="empty-icon">🎨</text>
      <text class="empty-text">点击下方素材开始创作吧</text>
    </view>

    <!-- 选中元素的工具栏 -->
    <view wx:if="{{selectedIdx >= 0 && elements.length > 0}}" class="element-tools">
      <view class="tool-btn" bindtap="scaleUp"><text>🔍+</text></view>
      <view class="tool-btn" bindtap="scaleDown"><text>🔍-</text></view>
      <view class="tool-btn" bindtap="rotateLeft"><text>↩️</text></view>
      <view class="tool-btn" bindtap="rotateRight"><text>↪️</text></view>
      <view class="tool-btn tool-delete" bindtap="deleteElement"><text>🗑️</text></view>
    </view>
  </view>

  <!-- 描述输入框 -->
  <view class="desc-bar">
    <text class="desc-icon">💬</text>
    <input
      class="desc-input"
      placeholder="描述一下你的作品（选填）"
      placeholder-style="color: #CCC;"
      maxlength="50"
      value="{{description}}"
      bindinput="onDescInput"
      confirm-type="done"
    />
    <text class="desc-count">{{description.length}}/50</text>
  </view>

  <!-- 素材区域 -->
  <view class="material-panel">
    <!-- 分类 Tab -->
    <scroll-view class="category-tabs" scroll-x enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="tab-item {{activeCategory === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="switchCategory"
      >
        <text class="tab-icon">{{item.icon}}</text>
        <text class="tab-name">{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 素材网格 -->
    <scroll-view class="material-grid" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="grid-wrap">
        <view
          wx:for="{{filteredMaterials}}"
          wx:key="id"
          class="material-item"
          data-id="{{item.id}}"
          bindtap="addMaterialToCanvas"
        >
          <text wx:if="{{item.type === 'emoji'}}" class="material-emoji">{{item.content}}</text>
          <view wx:else class="material-color" style="background: {{item.content}};"></view>
          <text class="material-label">{{item.label}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <view class="btn-random" bindtap="randomMaterial">
        <text>🎲 随机素材</text>
      </view>
      <view class="btn-submit {{elements.length === 0 ? 'disabled' : ''}}" bindtap="doTransform">
        <text class="btn-submit-text">变变！✨</text>
      </view>
    </view>
  </view>
</view>
