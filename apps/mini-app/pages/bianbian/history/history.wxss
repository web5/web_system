/* ===== 变变历史页 v2 ===== */

.page {
  min-height: 100vh;
  background: #FFF8F0;
  box-sizing: border-box;
}

/* ===== 空态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 40rpx;
}

.empty-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #BBB;
  margin-bottom: 48rpx;
}

.btn-go {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #FF8C42, #FF6B35);
  border-radius: 48rpx;
  font-size: 30rpx;
  color: #FFF;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 66, 0.2);
}

/* ===== 管理栏 ===== */
.manage-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background: #FFF8F0;
  border-bottom: 1rpx solid rgba(255, 140, 66, 0.06);
}

.manage-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.manage-back {
  font-size: 28rpx;
  color: #FF8C42;
  padding: 8rpx 0;
}

.manage-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.manage-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.manage-btn {
  font-size: 26rpx;
  color: #FF8C42;
  padding: 8rpx 12rpx;
}

.manage-cancel {
  color: #888;
}

.manage-delete {
  color: #FF3B30;
  font-weight: 600;
}

/* ===== 数量统计 ===== */
.count-bar {
  text-align: center;
  padding: 16rpx 0 8rpx;
}

.count-bar text {
  font-size: 22rpx;
  color: #CCC;
}

/* ===== 3列网格 ===== */
.grid {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 20rpx;
  gap: 12rpx;
  padding-bottom: 40rpx;
}

.grid-item {
  position: relative;
  width: calc((100% - 24rpx) / 3);
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: #FFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.grid-img {
  width: 100%;
  height: 100%;
}

.grid-time {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx 12rpx;
  font-size: 18rpx;
  color: #FFF;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  text-align: center;
}

.check-mark {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #FFF;
  background: rgba(0, 0, 0, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-mark.checked {
  background: #FF8C42;
  border-color: #FF8C42;
}

.check-mark text {
  font-size: 28rpx;
  color: #FFF;
  font-weight: 700;
}

/* 底部提示 */
.grid-footer {
  text-align: center;
  padding: 24rpx;
}

.grid-footer text {
  font-size: 22rpx;
  color: #CCC;
}

/* ===== 大图预览 Sheet ===== */
.preview-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.preview-sheet {
  width: 100%;
  background: #FFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.preview-img {
  width: 90%;
  aspect-ratio: 1;
  border-radius: 20rpx;
  background: #FFF8F0;
  margin-bottom: 32rpx;
}

.preview-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
  margin-bottom: 20rpx;
}

.preview-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-btn:first-child {
  background: linear-gradient(135deg, #FF8C42, #FF6B35);
  color: #FFF;
}

.preview-btn-delete {
  background: #FFF;
  color: #FF3B30;
  border: 2rpx solid rgba(255, 59, 48, 0.15);
}

.preview-close {
  width: 100%;
  height: 88rpx;
  border-radius: 24rpx;
  border: none;
  font-size: 28rpx;
  color: #888;
  background: #FFF8F0;
  display: flex;
  align-items: center;
  justify-content: center;
}
