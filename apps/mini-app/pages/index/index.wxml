<view class="container {{isLandscape ? 'landscape' : ''}} {{isIPad ? 'ipad' : ''}}">
  <!-- Logo -->
  <view class="app-logo">
    <image class="logo-img" src="data:image/svg+xml;base64," mode="aspectFit" />
    <text class="logo-text">科豆 AI</text>
  </view>

  <!-- Hero -->
  <view class="hero">
    <text class="title">创意画板</text>
    <text class="subtitle">释放你的想象力</text>
    <text wx:if="{{!isLandscape}}" class="status">AI 赋能 · 随心创作</text>
  </view>

  <!-- Features -->
  <view class="features">
    <button class="feature-btn draw-btn" bindtap="goToDraw">
      <text class="feature-icon">🎨</text>
      <text class="feature-text">开始画画</text>
    </button>
    <button class="feature-btn records-btn" bindtap="goToRecords">
      <text class="feature-icon">🖼️</text>
      <text class="feature-text">我的画作</text>
    </button>
  </view>

  <!-- 变变入口 -->
  <view class="bianbian-entry" bindtap="goToBianbian">
    <view class="bianbian-glow"></view>
    <view class="bianbian-content">
      <text class="bianbian-emoji">✨</text>
      <view class="bianbian-info">
        <text class="bianbian-name">变变</text>
        <text class="bianbian-desc">把想象，变出来</text>
      </view>
      <text class="bianbian-arrow">→</text>
    </view>
  </view>
</view>
