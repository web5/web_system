<view class="container {{isLandscape ? 'landscape' : ''}} {{isIPad ? 'ipad' : ''}}">
  <!-- Logo -->
  <view class="app-logo">
    <image class="logo-img" src="data:image/svg+xml;base64," mode="aspectFit" />
    <text class="logo-text">科豆 AI</text>
  </view>
  <!-- 横屏时 hero + features 左右分栏 -->
  <view class="hero">
    <text class="title">创意画板</text>
    <text class="subtitle">让孩子自由创作，激发想象力</text>
    <text class="status">{{loggedIn ? '✅ 已登录' : '⏳ 登录中...'}}</text>
  </view>

  <view class="features">
    <button class="feature-btn draw-btn" bindtap="goToDraw">
      <text class="feature-icon">🎨</text>
      <text class="feature-text">开始画画</text>
    </button>
    <button class="feature-btn records-btn" bindtap="goToRecords">
      <text class="feature-icon">📋</text>
      <text class="feature-text">我的画作</text>
    </button>
  </view>
</view>
