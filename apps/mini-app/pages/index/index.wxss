.container {
  padding: 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
}

.hero {
  text-align: center;
  padding: 60rpx 0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  display: block;
}

/* 功能按钮区域 */
.features {
  display: flex;
  justify-content: center;
  margin: 60rpx 0;
}

.feature-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 400rpx;
  height: 300rpx;
  border-radius: 30rpx;
  color: white;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.feature-btn::after {
  border: none;
}

.draw-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.feature-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.feature-text {
  font-size: 32rpx;
  font-weight: bold;
}
