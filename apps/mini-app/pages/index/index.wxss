/* ===== 科豆 AI — Dark Cinema Orange 首页 ===== */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 10vh 5% 8vh;
  background: linear-gradient(180deg, #000000 0%, #0A0A0D 40%, rgba(249,115,22,0.06) 100%);
}

.app-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 4vh;
}
.logo-img {
  width: 24vw;
  height: 26vw;
  max-width: 120rpx;
  max-height: 130rpx;
}
.logo-text {
  margin-top: 2vw;
  font-size: 3.6vw;
  font-weight: 700;
  color: #F97316;
  letter-spacing: 4rpx;
}

.hero {
  text-align: center;
  margin-bottom: 6vh;
}

.title {
  display: block;
  font-size: 6.4vw;
  font-weight: bold;
  color: #F8FAFC;
  margin-bottom: 2.6vw;
}

.subtitle {
  display: block;
  font-size: 3.8vw;
  color: #CBD5E1;
}

.status {
  display: block;
  font-size: 3.2vw;
  color: #94A3B8;
  margin-top: 2vw;
}

.features {
  display: flex;
  justify-content: center;
  width: 100%;
  gap: 5%;
}

.feature-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  max-width: 48%;
  aspect-ratio: 4 / 3;
  border-radius: 6%;
  color: white;
  font-size: 4vw;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
  transition: transform 0.15s;
}
.feature-btn:active {
  transform: scale(0.95);
}
.feature-btn::after {
  border: none;
}

/* 开始画画 — 橙色渐变 */
.draw-btn {
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
}

/* 我的画作 — 深色玻璃 */
.records-btn {
  background: linear-gradient(135deg, #1E1B4B 0%, #111827 100%);
  border: 1rpx solid rgba(249,115,22,0.2);
}

.feature-icon {
  font-size: 10vw;
  margin-bottom: 1.5vh;
}

.feature-text {
  font-size: 4vw;
  font-weight: bold;
}

/* ===== 横屏 + iPad ===== */
.container.landscape {
  padding: 6vh 5% 4vh;
}
.container.landscape .hero { margin-bottom: 3vh; }
.container.landscape .title { font-size: 4.2vw; margin-bottom: 1.2vw; }
.container.landscape .subtitle { font-size: 2.8vw; }
.container.landscape .status { font-size: 2.4vw; margin-top: 1vw; }
.container.landscape .features { gap: 4%; }
.container.landscape .feature-btn { max-width: 46%; border-radius: 5%; }
.container.landscape .feature-icon { font-size: 7vw; margin-bottom: 1vh; }
.container.landscape .feature-text { font-size: 3vw; }

.ipad:not(.landscape) { padding: 8vh 8% 6vh; }
.ipad:not(.landscape) .hero { margin-bottom: 8vh; }
.ipad:not(.landscape) .title { font-size: 7vw; margin-bottom: 3vw; }
.ipad:not(.landscape) .subtitle { font-size: 4.5vw; }
.ipad:not(.landscape) .features { gap: 6%; }
.ipad:not(.landscape) .feature-btn { max-width: 46%; border-radius: 5%; }
.ipad:not(.landscape) .feature-icon { font-size: 14vw; margin-bottom: 2vh; }
.ipad:not(.landscape) .feature-text { font-size: 4.5vw; }

.landscape.ipad { padding: 5vh 8% 4vh; }
.landscape.ipad .hero { margin-bottom: 4vh; }
.landscape.ipad .title { font-size: 5.5vw; margin-bottom: 2vw; }
.landscape.ipad .subtitle { font-size: 3.8vw; }
.landscape.ipad .status { font-size: 3vw; margin-top: 2vw; }
.landscape.ipad .features { width: 80%; gap: 6%; }
.landscape.ipad .feature-btn { max-width: 44%; border-radius: 5%; }
.landscape.ipad .feature-icon { font-size: 10vw; margin-bottom: 1.5vh; }
.landscape.ipad .feature-text { font-size: 4vw; }
