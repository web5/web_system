/* ===== 科豆 AI — 暖色首页 ===== */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 8vh 6% 6vh;
  background: linear-gradient(180deg, #FFFBF5 0%, #FFF8F0 100%);
}

/* ===== Logo ===== */
.app-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 5vh;
}
.logo-img {
  width: 22vw;
  height: 24vw;
  max-width: 110rpx;
  max-height: 120rpx;
}
.logo-text {
  margin-top: 2vw;
  font-size: 3.4vw;
  font-weight: 700;
  color: #F97316;
  letter-spacing: 4rpx;
}

/* ===== 产品分区 ===== */
.product-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 变变 — 主打 */
.product-section.primary { margin-bottom: 0; }

/* 画板 — 次要 */
.product-section.secondary {
  margin-top: 5vh;
  padding-top: 5vh;
  border-top: 1rpx solid rgba(255, 140, 66, 0.08);
}

/* ===== 分区头部 ===== */
.section-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 2vh;
}

.product-badge {
  font-size: 3vw;
  font-weight: 600;
  color: #FF8C42;
  letter-spacing: 2rpx;
}
.product-badge.primary {
  padding: 4rpx 14rpx;
  background: linear-gradient(135deg, #FF8C42, #FFB347);
  color: #fff;
  border-radius: 20rpx;
  font-size: 2.6vw;
}

.product-title {
  font-size: 5.6vw;
  font-weight: 800;
  color: #333;
  letter-spacing: 2rpx;
}
.product-title.secondary {
  font-size: 4.4vw;
  color: #666;
}

/* ===== 产品描述 ===== */
.product-desc {
  font-size: 3.4vw;
  color: #888;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 3.5vh;
}
.product-desc.secondary {
  font-size: 3vw;
  color: #aaa;
  margin-bottom: 2.5vh;
}

/* ===== 变变 — 主按钮 ===== */
.primary-btn {
  width: 80%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #FF8C42 0%, #FFB347 100%);
  color: #fff;
  font-size: 4.4vw;
  font-weight: 700;
  border: none;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 140, 66, 0.35);
  transition: transform 0.15s;
}
.primary-btn:active {
  transform: scale(0.96);
}
.primary-btn::after {
  border: none;
}
.primary-btn-icon {
  font-size: 5vw;
}

/* ===== 画板 — 次要按钮组 ===== */
.secondary-actions {
  display: flex;
  width: 100%;
  gap: 4%;
}

.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  flex: 1;
  padding: 22rpx 0;
  font-size: 3.4vw;
  font-weight: 600;
  border: none;
  border-radius: 28rpx;
  transition: transform 0.15s;
}
.secondary-btn:active {
  transform: scale(0.95);
}
.secondary-btn::after {
  border: none;
}

.draw-btn {
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.25);
}

.records-btn {
  background: #fff;
  color: #666;
  border: 1rpx solid rgba(255, 140, 66, 0.12);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.secondary-btn-icon {
  font-size: 4vw;
}

/* ===== 横屏 ===== */
.container.landscape {
  padding: 5vh 8% 4vh;
}
.container.landscape .app-logo { margin-bottom: 3vh; }
.container.landscape .logo-img { width: 14vw; height: 15vw; }
.container.landscape .logo-text { font-size: 2.6vw; }
.container.landscape .product-title { font-size: 4vw; }
.container.landscape .product-title.secondary { font-size: 3.4vw; }
.container.landscape .product-desc { font-size: 2.6vw; margin-bottom: 2vh; }
.container.landscape .product-desc.secondary { font-size: 2.4vw; }
.container.landscape .primary-btn { width: 60%; padding: 20rpx 0; font-size: 3.4vw; }
.container.landscape .secondary-btn { padding: 16rpx 0; font-size: 2.8vw; }
.container.landscape .product-section.secondary { margin-top: 3vh; padding-top: 3vh; }
.container.landscape .primary-btn-icon { font-size: 4vw; }
.container.landscape .secondary-btn-icon { font-size: 3.2vw; }
.container.landscape .product-badge { font-size: 2.4vw; }
.container.landscape .product-badge.primary { font-size: 2vw; padding: 2rpx 12rpx; }

/* ===== iPad 竖屏 ===== */
.ipad:not(.landscape) {
  padding: 6vh 10% 5vh;
}
.ipad:not(.landscape) .app-logo { margin-bottom: 6vh; }
.ipad:not(.landscape) .logo-img { width: 18vw; height: 20vw; }
.ipad:not(.landscape) .logo-text { font-size: 3vw; }
.ipad:not(.landscape) .product-title { font-size: 5vw; }
.ipad:not(.landscape) .product-title.secondary { font-size: 4vw; }
.ipad:not(.landscape) .product-desc { font-size: 3vw; }
.ipad:not(.landscape) .primary-btn { width: 70%; padding: 32rpx 0; }
.ipad:not(.landscape) .secondary-actions { gap: 6%; }
.ipad:not(.landscape) .secondary-btn { padding: 28rpx 0; }
.ipad:not(.landscape) .product-section.secondary { margin-top: 6vh; padding-top: 6vh; }

/* ===== iPad 横屏 ===== */
.landscape.ipad {
  padding: 4vh 12% 3vh;
}
.landscape.ipad .app-logo { margin-bottom: 4vh; }
.landscape.ipad .product-section.secondary { margin-top: 4vh; padding-top: 4vh; }
.landscape.ipad .primary-btn { width: 55%; }
.landscape.ipad .secondary-actions { width: 80%; }
