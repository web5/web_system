/* ===== 科豆 AI — Dark Cinema Orange 画作记录 ===== */
.container {
  min-height: 100vh;
  background: #000000;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #0A0A0D;
  border-bottom: 1rpx solid rgba(249,115,22,0.12);
}
.header-logo { margin-right: 16rpx; }
.logo-img-mini { width: 48rpx; height: 52rpx; }
.header-info { display: flex; flex-direction: column; }
.header-title { font-size: 32rpx; font-weight: bold; color: #F8FAFC; }
.header-count { font-size: 24rpx; color: #94A3B8; }

.record-list { flex: 1; padding: 20rpx 30rpx; }
.record-item {
  display: flex; align-items: center;
  background: #0C0C0D;
  border: 1rpx solid rgba(249,115,22,0.08);
  border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx;
  position: relative;
}

.record-thumb {
  width: 120rpx; height: 120rpx; border-radius: 14rpx; overflow: hidden;
  flex-shrink: 0; margin-right: 24rpx;
}
.thumb-img { width: 100%; height: 100%; }
.thumb-placeholder {
  width: 100%; height: 100%;
  background: linear-gradient(135deg, #111115 0%, #1E1B4B 100%);
  display: flex; align-items: center; justify-content: center;
}
.thumb-icon { font-size: 48rpx; }
.record-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; gap: 10rpx; }
.record-name { font-size: 30rpx; font-weight: 600; color: #F8FAFC; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.record-time { font-size: 24rpx; color: #94A3B8; }

.edit-row { display: flex; align-items: center; gap: 12rpx; }
.edit-input { flex: 1; height: 56rpx; background: #111115; border-radius: 8rpx; padding: 0 16rpx; font-size: 28rpx; color: #F8FAFC; border: 2rpx solid #F97316; }
.edit-actions { display: flex; gap: 8rpx; flex-shrink: 0; }
.edit-btn { width: 48rpx; height: 48rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 26rpx; font-weight: bold; }
.edit-btn.confirm { background: #F97316; color: #fff; }
.edit-btn.cancel { background: #18181B; color: #94A3B8; }

.record-delete { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-left: 10rpx; }
.delete-icon { font-size: 32rpx; opacity: 0.4; }

.empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: #94A3B8; margin-bottom: 40rpx; }
.empty-btn { background: #F97316; color: #fff; font-size: 30rpx; border-radius: 40rpx; padding: 16rpx 60rpx; border: none; }
.empty-btn::after { border: none; }

.footer-bar { padding: 20rpx 30rpx 40rpx; background: #000000; }
.new-btn { background: #F97316; color: #fff; font-size: 30rpx; font-weight: bold; border-radius: 40rpx; padding: 20rpx; border: none; }
.new-btn::after { border: none; }

/* iPad 适配 */
.ipad:not(.landscape) .header { padding: 48rpx 60rpx 28rpx; }
.ipad:not(.landscape) .header-title { font-size: 42rpx; }
.ipad:not(.landscape) .record-list { padding: 28rpx 60rpx; }
.ipad:not(.landscape) .record-thumb { width: 160rpx; height: 160rpx; }
.ipad:not(.landscape) .record-name { font-size: 34rpx; }
.ipad:not(.landscape) .record-time { font-size: 26rpx; }

.ipad.landscape .record-list { display: flex; flex-wrap: wrap; padding: 40rpx; gap: 30rpx; }
.ipad.landscape .record-item { width: calc(50% - 15rpx); flex-direction: column; align-items: flex-start; padding: 32rpx; margin-bottom: 0; }
.ipad.landscape .record-thumb { width: 100%; height: 280rpx; margin-right: 0; margin-bottom: 20rpx; }
.ipad.landscape .record-info { width: 100%; min-width: auto; }
.ipad.landscape .record-name { font-size: 32rpx; white-space: normal; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.ipad.landscape .record-time { font-size: 24rpx; }
.ipad.landscape .record-delete { position: absolute; top: 20rpx; right: 20rpx; margin-left: 0; }
.ipad.landscape .header { padding: 40rpx 60rpx 24rpx; }
.ipad.landscape .header-title { font-size: 48rpx; }
.ipad.landscape .header-count { font-size: 28rpx; }
.ipad.landscape .footer-bar { padding: 30rpx 60rpx 48rpx; }
.ipad.landscape .new-btn { font-size: 34rpx; padding: 24rpx; }
