.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #f97316;
  padding: 40rpx;
  box-sizing: border-box;
}

/* 品牌Logo */
.app-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}
.logo-img {
  width: 88rpx;
  height: 96rpx;
}
.logo-text {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(255,255,255,.85);
  letter-spacing: 4rpx;
}

.status-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.icon-area {
  margin-bottom: 40rpx;
}

.icon-scan,
.icon-loading,
.icon-success,
.icon-fail {
  font-size: 120rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.success-text {
  color: #52c41a;
}

.fail-text {
  color: #ff4d4f;
}

.desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 60rpx;
}

.scan-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.scan-btn::after {
  border: none;
}

.scan-btn:active {
  opacity: 0.8;
}
