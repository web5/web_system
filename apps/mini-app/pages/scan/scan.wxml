<view class="container">
  <!-- Logo -->
  <view class="app-logo">
    <image class="logo-img" src="data:image/svg+xml;base64," mode="aspectFit" />
    <text class="logo-text">科豆 AI</text>
  </view>

  <view class="scan-area">
    <text class="scan-title">扫码登录</text>
    <text class="scan-tip">请使用微信扫描二维码</text>
    <view class="qrcode-box">
      <canvas class="qrcode" canvas-id="qrcode" type="2d" wx:if="{{!token}}"/>
      <view class="qrcode-placeholder" wx:else>
        <text class="qr-icon">✅</text>
        <text class="qr-text">已扫码</text>
        <text class="qr-sub">请在手机上确认登录</text>
      </view>
    </view>
  </view>
</view>
