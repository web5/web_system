<view class="container">
  <!-- Logo -->
  <view class="app-logo">
    <image class="logo-img" src="data:image/svg+xml;base64," mode="aspectFit" />
    <text class="logo-text">科豆 AI</text>
  </view>
  <view class="status-area">
    <block wx:if="{{status === 'idle'}}">
      <view class="icon-area">
        <text class="icon-scan">📷</text>
      </view>
      <text class="title">网页扫码登录</text>
      <text class="desc">扫描网页上的二维码，确认登录</text>
      <button class="scan-btn" bindtap="startScan">开始扫码</button>
    </block>

    <block wx:elif="{{status === 'scanning'}}">
      <view class="icon-area">
        <text class="icon-loading">⏳</text>
      </view>
      <text class="title">正在扫码...</text>
      <text class="desc">请将摄像头对准网页上的二维码</text>
    </block>

    <block wx:elif="{{status === 'confirming'}}">
      <view class="icon-area">
        <text class="icon-loading">🔄</text>
      </view>
      <text class="title">正在确认登录...</text>
      <text class="desc">请稍候</text>
    </block>

    <block wx:elif="{{status === 'success'}}">
      <view class="icon-area">
        <text class="icon-success">✅</text>
      </view>
      <text class="title success-text">登录确认成功</text>
      <text class="desc">请返回网页查看</text>
    </block>

    <block wx:elif="{{status === 'fail'}}">
      <view class="icon-area">
        <text class="icon-fail">❌</text>
      </view>
      <text class="title fail-text">登录失败</text>
      <text class="desc">{{message}}</text>
      <button class="scan-btn" bindtap="retry">重新扫码</button>
    </block>
  </view>
</view>
