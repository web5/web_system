<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FFD700;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#FFA500;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- 背景圆形 -->
  <circle cx="50" cy="50" r="50" fill="url(#bg)"/>
  
  <!-- 脸 -->
  <circle cx="50" cy="45" r="25" fill="#FFF5E4"/>
  
  <!-- 眼睛 -->
  <ellipse cx="40" cy="42" rx="4" ry="5" fill="#333"/>
  <ellipse cx="60" cy="42" rx="4" ry="5" fill="#333"/>
  
  <!-- 眼睛高光 -->
  <circle cx="41" cy="40" r="2" fill="#FFF"/>
  <circle cx="61" cy="40" r="2" fill="#FFF"/>
  
  <!-- 嘴巴 -->
  <path d="M 40 55 Q 50 62 60 55" stroke="#FF6B6B" stroke-width="3" fill="none" stroke-linecap="round"/>
  
  <!-- 腮红 -->
  <ellipse cx="35" cy="50" rx="5" ry="3" fill="#FFB6C1" opacity="0.6"/>
  <ellipse cx="65" cy="50" rx="5" ry="3" fill="#FFB6C1" opacity="0.6"/>
  
  <!-- 头发 -->
  <path d="M 25 40 Q 30 20 50 20 Q 70 20 75 40 Q 75 35 70 30 Q 65 25 50 25 Q 35 25 30 30 Q 25 35 25 40" fill="#8B4513"/>
</svg>
